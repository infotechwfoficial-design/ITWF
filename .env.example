# --- SUPABASE ---
# URL e chave pública (usados pelo frontend React - prefixo VITE_)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço (usada pelo backend server.ts - NÃO expor no frontend!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- URL DO BACKEND (Render) ---
# URL completa do seu Web Service no Render
VITE_API_URL=https://itwf.onrender.com

# URL do app frontend (Vercel) - usada nas notificações push
VITE_APP_URL=https://itwf.vercel.app

# --- NOTIFICAÇÕES WEB PUSH (VAPID) ---
# Gere com: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BHxacd_CxUxPuwPGqmyySkDTNHvop0IKLyZ3EExEmMMEDlMoFXntORvw_Ss7dI-2XNjoGRT-EZmUk5O4qEGZ76o
VAPID_PRIVATE_KEY=SchGx25Ck70ZzpiHBIB2zhiob5bSxEACbM38AqqyOIw
VAPID_EMAIL=mailto:contato@itwf.com

# --- GOOGLE GEMINI (IA / Chatbot) ---
GEMINI_API_KEY=AIzaSy...

# --- FIREBASE ADMIN (Notificações Mobile Nativas) ---
# Cole o conteúdo do JSON do Service Account do Firebase em uma única linha
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# --- TMDB (Busca de Filmes e Séries) ---
VITE_TMDB_API_KEY=

# --- MERCADO PAGO (Pagamentos - Opcional) ---
# Configurado via painel Admin. A chave é salva no Supabase.

# --- CORS (Backend) ---
# Adicione aqui outros domínios permitidos separados por vírgula
# Ex: https://meusite.com,https://meusite-preview.vercel.app
ALLOWED_ORIGINS=https://itwf.vercel.app

# --- RENDER (Keep-alive) ---
RENDER_EXTERNAL_URL=https://itwf.onrender.com

# --- SPORTMONKS (Placar ao Vivo - Opcional) ---
